import java.util.*;
public class Main {
	public static int minNumOfCoinsGreedy(int[] coins, int target) {
		Arrays.sort(coins);
		int count = 0;
		for(int i=coins.length-1; i>=0; i--) {
			while(target>=coins[i]) {
				target -= coins[i];
				count++;
			}
			if(target==0) break;
		}
		if(target!=0) return -1;
		return count;
	}
	public static void main(String[] args) {
		int[] arr = {1,3,4};
		int target = 6;
		int ans = minNumOfCoinsGreedy(arr, target);
		System.out.println(ans);
	}
}
